# ===== Twilio =====
# Console → Voice → A Number → Webhook URL = https://${NGROK_DOMAIN}/voice (HTTP POST)
TWILIO_ACCOUNT_SID=AC_your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ===== AI providers =====
# Primary: Claude Haiku 4.5 (low-latency, native tool_use)
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Fallback: Groq Llama 3.3 70B (LPU-fast, provider diversity)
GROQ_API_KEY=gsk_your_key_here

# ===== ngrok (public HTTPS tunnel for Twilio webhook) =====
# Get authtoken from https://dashboard.ngrok.com/get-started/your-authtoken.
NGROK_AUTHTOKEN=your_ngrok_authtoken

# Optional but recommended: lock the tunnel to your reserved free-tier subdomain so it
# can't silently rotate. Bare host only (no https://). Find your subdomain in the
# ngrok dashboard or via the inspector at http://localhost:4040 on first run.
# Leave blank to fall back to ngrok's per-account auto-bind.
NGROK_DOMAIN=your-subdomain.ngrok-free.dev

# ===== Database (matches docker-compose service names) =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=callwise
DB_USER=postgres
DB_PASSWORD=postgres

# Host-side port for Postgres (only affects what your laptop sees: psql, DBeaver, etc.).
# The app inside docker still connects to postgres:5432 over the compose network.
# Default 5433 dodges a local Postgres install. Change if it also clashes.
DB_HOST_PORT=5433

# ===== Application =====
# Port Spring listens on INSIDE the container. Don't change unless you also update the
# ngrok service which forwards to app:8080.
APP_PORT=8080
# Host-side port for the app. Hit http://localhost:${APP_HOST_PORT} from your laptop.
APP_HOST_PORT=8088
# Host-side port for the ngrok inspector UI.
NGROK_INSPECTOR_PORT=4041
LOG_LEVEL=INFO
SPRING_PROFILES_ACTIVE=default

# ===== Tier 3 (Visual Diagnosis) =====
# Real SMTP so a remote reviewer receives upload-link emails in their actual inbox.
# Defaults target Gmail. MAIL_PASSWORD MUST be a Google App Password
# (https://myaccount.google.com/apppasswords) — regular account passwords are rejected
# when 2-Step Verification is enabled.
#
# To swap providers (Resend, SES, Mailgun, etc.) just change MAIL_HOST/PORT/USERNAME and
# the API-key/password — application.yml reads everything from these env vars.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your.address@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=Your Name <your.address@gmail.com>

# Public base URL embedded in upload links sent by email. Use the ngrok URL the
# tunnel container prints on first start (e.g. https://abc123.ngrok-free.dev). Twilio's
# voice webhook should point at the same domain — keep them in sync.
PUBLIC_BASE_URL=https://your-ngrok-domain.ngrok-free.dev

# Where uploaded photos land inside the container. The compose file mounts ./uploads to this path.
UPLOAD_DIR=/app/uploads
# 10 MiB hard cap on uploaded image size — also enforced by spring.servlet.multipart.
UPLOAD_MAX_BYTES=10485760
# Upload links expire 30 minutes after creation.
UPLOAD_TOKEN_TTL_MINUTES=30
