# ===== Twilio =====
# Console → Voice → A Number → Webhook URL = https://${NGROK_DOMAIN}/voice (HTTP POST)
TWILIO_ACCOUNT_SID=AC_your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ===== AI providers =====
# Primary: Claude Haiku 4.5 (low-latency, native tool_use)
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Fallback: Groq Llama 3.3 70B (LPU-fast, provider diversity)
GROQ_API_KEY=gsk_your_key_here

# ===== ngrok (public HTTPS tunnel for Twilio webhook) =====
# Get authtoken from https://dashboard.ngrok.com/get-started/your-authtoken.
# The free tier auto-binds one persistent *.ngrok-free.dev domain to your account —
# whatever URL the ngrok container prints on first start will keep working across
# restarts. Point Twilio's webhook at it once and forget.
NGROK_AUTHTOKEN=your_ngrok_authtoken

# ===== Database (matches docker-compose service names) =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=callwise
DB_USER=postgres
DB_PASSWORD=postgres

# ===== Application =====
APP_PORT=8080
LOG_LEVEL=INFO
SPRING_PROFILES_ACTIVE=default

# ===== Tier 3 (Visual Diagnosis) =====
# MailHog runs in docker-compose; the app talks to it as `mailhog:1025` over plain SMTP (no auth).
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=no-reply@callwise.local

# Public base URL embedded in upload links sent by email. Use the ngrok URL the
# tunnel container prints on first start (e.g. https://abc123.ngrok-free.dev).
PUBLIC_BASE_URL=https://your-ngrok-domain.ngrok-free.dev

# Where uploaded photos land inside the container. The compose file mounts ./uploads to this path.
UPLOAD_DIR=/app/uploads
# 10 MiB hard cap on uploaded image size — also enforced by spring.servlet.multipart.
UPLOAD_MAX_BYTES=10485760
# Upload links expire 30 minutes after creation.
UPLOAD_TOKEN_TTL_MINUTES=30
